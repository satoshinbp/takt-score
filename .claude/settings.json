{
  "enabledPlugins": {
    "git@shinya-plugins": true
  },
  "extraKnownMarketplaces": {
    "shinya-plugins": {
      "source": {
        "source": "github",
        "repo": "0113shins/claude-plugin"
      },
      "autoUpdate": true
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/format-on-edit.sh",
            "statusMessage": "Formatting changed file..."
          }
        ]
      }
    ]
  }
}
