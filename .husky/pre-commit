#!/bin/sh

# frontend/src/components/ui/ は shadcn/ui が管理するファイルのため手動編集禁止
ui_files=$(git diff --cached --name-only --diff-filter=M | grep '^frontend/src/components/ui/' || true)

if [ -n "$ui_files" ]; then
  echo "Error: frontend/src/components/ui/ のファイルは shadcn/ui が管理しており、手動編集は禁止されています。"
  echo "該当ファイル:"
  echo "$ui_files" | sed 's/^/  /'
  exit 1
fi

cd frontend && npx lint-staged
